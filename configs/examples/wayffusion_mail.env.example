# Copy this file to `.secrets/wayffusion_mail.env` and edit the values.
# `.secrets/` is ignored by Git.
#
# QQ/Foxmail SMTP notes:
# - Use the SMTP authorization code, not your normal mailbox login password.
# - QQ SMTP over SSL normally uses smtp.qq.com:465.

EMAIL_TO="muadib@foxmail.com"
SMTP_PRESET="qq"
SMTP_HOST="smtp.qq.com"
SMTP_PORT="465"
SMTP_SSL="1"
SMTP_STARTTLS="0"
SMTP_USER="your_qq_or_foxmail_account"
SMTP_PASSWORD="your_smtp_authorization_code"
SMTP_FROM="your_qq_or_foxmail_account"
